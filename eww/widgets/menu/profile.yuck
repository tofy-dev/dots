(defwidget profile [height]
  (box :class "profile" :height height :orientation "h" :space-evenly false :valign "center"
    (image :class "profile-image"
        :image-width 100 :image-height 100
        :path "../../images/weeb.jpg")
    (label :class "profile-name" :text "tofy" :xalign "center" :hexpand true)))
