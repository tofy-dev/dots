(defwidget bar-time []
    (eventbox
    :onclick "eww open calendar"
    (box :class "bar-time" :valign "center"
      :space-evenly "false"
      (label :class "time" :text "${hour}:${min}"))))

(defpoll hour :interval "0.05s"
  `date | grep -o "..:..:.." | grep -o "..:.." | grep -o "[^:].." | tr -d ':'`)
(defpoll min :interval "0.05s"
  `date | grep -o "..:..:.." | grep -o "..:.." | grep -o ":.." | tr -d ':'`)
