(defwidget battery []
  (box :class "battery" :space-evenly false
    (label :class "battery-icon" 
           :text {EWW_BATTERY.BAT1.capacity > 90 ? "´ëÇ" : EWW_BATTERY.BAT1.capacity > 75 ? "´ëü" : EWW_BATTERY.BAT1.capacity > 50 ? "´ëé" : EWW_BATTERY.BAT1.capacity > 25 ? "´ëâ" : "´ëä"})
    (label :class "battery-percent" :text "${EWW_BATTERY.BAT1.capacity}%")))
