; ==================================================================================================
; Containers
; ==================================================================================================
(defwidget hover-cont [var varname ?transition ?duration]
  (box :class "revealer-on-container"
    (eventbox :class "eventbox"
              :onhover "eww update ${varname}=true"
              :onhoverlost "eww update ${varname}=false"
      (revealer :reveal var 
                :transition {transition ?: transition}
                :duration {duration ?: duration}
        (children)))))

; ==================================================================================================
; Widgets
; ==================================================================================================
; ----- Time ---------------------------------------------------------------------------------------
(defwidget time []
    (eventbox
    :onhover "eww open calendar"
    (box
      :space-evenly "false"
      :spacing 20
(box)
      (box :class "hour"
        hour)
      (box :class "min"
        min))))

(defpoll hour :interval "0.05s"
  `date | grep -o "..:..:.." | grep -o "..:.." | grep -o "[^:].." | tr -d ':'`)
(defpoll min :interval "0.05s"
  `date | grep -o "..:..:.." | grep -o "..:.." | grep -o ":.." | tr -d ':'`)
; ----- Time ---------------------------------------------------------------------------------------

; ----- Workspace ----------------------------------------------------------------------------------
(defwidget workspaces[width]
  (box :class "workspaces"
       :orientation "h"
       :halign "center"
       :valign "center"
       :spacing 5
       :width width
    (button :class {(active-workspace == " 1 ") ? "spc1 active" : "spc1 inactive"} 
            :onclick "sway workspace 1" "´ë®")
    (button :class {(active-workspace == " 2 ") ? "spc2 active" : "spc2 inactive"} 
            :onclick "sway workspace 2" "¯×ó")
    (button :class {(active-workspace == " 3 ") ? "spc3 active" : "spc3 inactive"} 
            :onclick "sway workspace 3" "´á▒")
    (button :class {(active-workspace == " 4 ") ? "spc4 active" : "spc4 inactive"} 
            :onclick "sway workspace 4" "´å╝")
    (button :class {(active-workspace == " 5 ") ? "spc5 active" : "spc5 inactive"} 
            :onclick "sway workspace 5" "´çÿ")
    (button :class {(active-workspace == " 6 ") ? "spc6 active" : "spc6 inactive"} 
            :onclick "sway workspace 6" "´äæ")
    (button :class {(active-workspace == " 7 ") ? "spc7 active" : "spc7 inactive"} 
            :onclick "sway workspace 7" "´äæ")
    (button :class {(active-workspace == " 8 ") ? "spc8 active" : "spc8 inactive"} 
            :onclick "sway workspace 8" "´äæ")
    (button :class {(active-workspace == " 9 ") ? "spc9 active" : "spc9 inactive"} 
            :onclick "sway workspace 9" "´äæ")
    (button :class {(active-workspace == " 10 ") ? "spc10 active" : "spc10 inactive"} 
            :onclick "sway workspace 10" "´äæ")))

(defpoll active-workspace :interval "0.05s" :initial 1
  `swaymsg -t get_tree | grep '"current_workspace": "' | grep -oE '".0?"' | tr '\"' ' '`)
; ----- Workspace ----------------------------------------------------------------------------------

; ----- Volume -------------------------------------------------------------------------------------
(defwidget volume []
  (eventbox :onhover `eww update volume=true && eww open media-player-tr`
            :onhoverlost "eww update volume=false"
    (box :orientation "h" :space-evenly "false" :class "volume"
      (box :visible pin-media-player :class  "pin-media-player" "´âù")
      (revealer :transition "slideleft" :reveal volume :duration "700ms"
        (scale :class "bright-bar" 
           :tooltip "Volume: ${current-volume}%" 
           :onchange "amixer -M sset Master {}%" 
           :flipped false :orientation "h" 
           :height 10 :width 140 :onhover "eww open media-player" :max 101 :min 0))
    (label :text "´Ç¿${player-image}")
    )))
(defvar volume false)
(defpoll current-volume :interval "1s" `amixer | grep -E 'Front Left: Playback' | grep -oE '\[.*\]' | grep -oE "\[.*\ " | tr -d '\[\]\%'`)
; ----- Volume -------------------------------------------------------------------------------------

; ----- Audio Player -------------------------------------------------------------------------------
(defwidget media-player [width]
    (box :class "media-player" :orientation "v" :valign "fill" :space-evenly false
      (box :space-evenly false :orientation "h"
          (image :class "player-image"
              :valign "start"
              :image-width 100
              :image-height 100
              :path image-path)
          (box :orientation "v" :width width
            (label
                :class "player-title"
                :limit-width 20
                :text player-title
                :xalign 0
                )
            (label
                :class "player-artist"
                :text player-artist
                :xalign 0
                )))
      (progress :value player-position :class "player-bar" :orientation "h")
      (media-buttons :height 30)))
(defvar image-path "./scripts/get_image/img")
(deflisten player-title `playerctl --player playerctld --follow metadata --format {{title}}`)
(deflisten player-artist `playerctl --player playerctld --follow metadata --format {{artist}}`)
(defpoll player-position :interval "0.1s" `playerctl metadata --format "{{ position/mpris:length*100 }}"`)
(defpoll player-image :interval "0.5s" `~/.config/eww/scripts/get_image/get_image.sh`)

(defwidget media-buttons [height]
  (box :valign "fill" :height height
    (button :timeout "3s" :onclick "playerctl previous" (label :class "media-button prev" :yalign 0.5 :text "´ª¡"))
    (button :timeout "3s" :onclick "playerctl play-pause && eww update play-pause='${play-pause == "´úú" ? "´üï" : "´úú"}'" (label :class "media-button pause" :yalign 0.5 :text play-pause))
    (button :timeout "3s" :onclick "playerctl next" (label :class "media-button skip" :yalign 0.5 :text "´ª¼"))))
(defvar play-pause "´úú")
; ----- Audio Player -------------------------------------------------------------------------------

; ----- Brightness ---------------------------------------------------------------------------------
(defwidget bright []
  (eventbox :onhover "eww update bright=true" :onhoverlost "eww update bright=false"
    (box :orientation "h" :space-evenly "false" :class "bright"
    (revealer :transition "slideleft" :reveal bright :duration "700ms"
    (scale :class "bright-bar" 
           :value current-brightness 
           :tooltip "Brightness: ${current-brightness}%" 
           :onchange "brightnessctl set {}%" 
           :flipped false :orientation "h" 
           :height 10 :width 140 :max 101 :min 0))
      (label :text "´ù×"))))
(defvar bright false)
(defpoll current-brightness :interval "1s" `brightnessctl -m -d amdgpu_bl0 | awk -F, '{print substr($4, 0, length($4)-1)}' | tr -d '%'`)
; ----- Brightness ---------------------------------------------------------------------------------

; ----- Power --------------------------------------------------------------------------------------
(defwidget power []
	(eventbox	:onhover "eww update power=true" :onhoverlost "eww update power=false" 
	(box		:orientation "h" :space-evenly "false" :vexpand "false" :valign "end" :class "power-menu"
	(revealer	:transition "slideleft" :reveal power	:duration "550ms"
    (box		:orientation "h" :space-evenly "false"
          (box)
          (button   :class "power-button reboot"  			
                    :tooltip "Restart" 
                    :onclick "reboot" "´░ç" )
          (button	:class "power-button logout"					
                    :tooltip "Logoff"		 
                    :onclick "swaymsg exit"	"´£à")
          (button	:class "power-button lock" 				
                    :tooltip "Lock Screen"
                    :onclick "~/Coding/scripts/lockscreen.sh" "´Çú")))
          (button	:class "power-button off"					
                    :tooltip "Shutdown"		 
                    :onclick "poweroff" "´Çæ"))))
(defvar power false)
; ----- Power --------------------------------------------------------------------------------------

; ----- Sections -----------------------------------------------------------------------------------
(defwidget top[]
  (box :width 610
    (box :halign "start" :width 300 (time))))
(defwidget mid[]
  (box :width 700
    (workspaces :width 400)))
(defwidget bot[]
  (box :width 610
    (box :orientation "h" :valign "center" :halign "end" :space-evenly false :spacing 30
      (volume)
      (bright)
      (power)
    )))
; ----- Sections -----------------------------------------------------------------------------------

; ==================================================================================================
; Windows 
; ==================================================================================================
(defwindow sideways_bar
    ; -----------------------properties-----------------------
    :monitor 0
    :geometry (geometry
        :x "0px"
        :y "0px"
        :width "100%"
        :height "45px"
        :anchor "center top"
    )
    :stacking "bottom"
    :exclusive true

    ; -----------------------widgets-----------------------
    (box
      :orientation "h"
      :valign "top"
      :space-evenly false
      (top)
      (mid)
      (bot)
    ))

(defwindow calendar 
   :monitor 0
   :geometry (geometry :x "0px"
                       :y "0px"
                       :width "300px"
                       :height "50px"
                       :anchor "top left")
   :stacking "fg"
   (eventbox :onhoverlost "eww close calendar"
        (calendar)))

(defwindow media-player-tr
   :monitor 0 :geometry (geometry :x "0px" :y "0px" :width "400px" :height "125px" :anchor "top right") :stacking "fg"
   (eventbox :onhoverlost {pin-media-player ? "" : "eww close media-player-tr"}
             :onrightclick "eww update pin-media-player='${pin-media-player ? false : true}'"
        (media-player :width 350)))
(defvar pin-media-player false)
